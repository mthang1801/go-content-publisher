APP_NAME=content-bot-go
APP_ENV=development
APP_LOG_LEVEL=info

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s

# Prefer DATABASE_URL for Supabase.
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_HOST=db.[YOUR-PROJECT-REF].supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=[YOUR-PASSWORD]
DATABASE_SSL_MODE=require
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m

TWITTER_BEARER_TOKEN=
TWITTER_VI_API_KEY=
TWITTER_VI_API_SECRET=
TWITTER_VI_ACCESS_TOKEN=
TWITTER_VI_ACCESS_SECRET=
TWITTER_EN_API_KEY=
TWITTER_EN_API_SECRET=
TWITTER_EN_ACCESS_TOKEN=
TWITTER_EN_ACCESS_SECRET=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Tooling-only values for container/image workflows, not DB-backed runtime settings.
DOCKER_IMAGE_NAME=content-bot-go
DOCKER_IMAGE_TAG=dev
COMPOSE_PROJECT_NAME=content-bot-go
